  "processStations": [
    { "stationId": "process-01", "order": 1, "title": "Nấu vỏ cây Dó", "titleEn": "Cooking the Dó Bark", "narration": "Vỏ cây dó được nấu với vôi để làm mềm sợi trước các công đoạn tiếp theo.", "narrationEn": "Dó bark is cooked with lime to soften the fibers before the next stages.", "assetId": "process-video-01" },
    { "stationId": "process-02", "order": 2, "title": "Làm bìa vỏ Dó", "titleEn": "Making Cover Sheet", "narration": "Vỏ đã nấu được ngâm rửa, làm sạch và xử lý sơ bộ.", "narrationEn": "Cooked bark is washed, cleaned, and prepared.", "assetId": "process-video-02" },
    { "stationId": "process-03", "order": 3, "title": "Giã bột Dó", "titleEn": "Pounding the Pulp", "narration": "Sợi vỏ dó được giã thành bột giấy mịn.", "narrationEn": "Dó fibers are pounded into fine paper pulp.", "assetId": "process-video-03" },
    { "stationId": "process-04", "order": 4, "title": "Đập lề và bào gỗ", "titleEn": "Trimming and Wood Shaving", "narration": "Công đoạn chuẩn bị mép giấy và khuôn cho bể xeo.", "narrationEn": "This stage prepares the paper edges and tools for sheet forming.", "assetId": "process-video-04" },
    { "stationId": "process-05", "order": 5, "title": "Đãi bìa xơ", "titleEn": "Sifting the Pulp", "narration": "Bột giấy được đãi để loại bỏ phần vỏ cứng và tạp chất.", "narrationEn": "The pulp is sifted to remove hard bark and impurities.", "assetId": "process-video-05" },
    { "stationId": "process-06", "order": 6, "title": "Pha keo tàu", "titleEn": "Mixing with Glue", "narration": "Nhựa cây mò được pha vào bể bột để hỗ trợ liên kết sợi.", "narrationEn": "Natural glue is mixed into the pulp vat to support fiber bonding.", "assetId": "process-video-06" },
    { "stationId": "process-07", "order": 7, "title": "Seo giấy Dó", "titleEn": "Scooping the Sheets", "narration": "Người thợ chao liềm xeo để dàn sợi thành tờ giấy mỏng.", "narrationEn": "The maker uses a mould to spread fibers into a thin sheet.", "assetId": "process-video-07" },
    { "stationId": "process-08", "order": 8, "title": "Ép giấy thoát nước", "titleEn": "Pressing the Paper", "narration": "Các tờ giấy ướt được ép để loại bớt nước.", "narrationEn": "Wet sheets are pressed to remove water.", "assetId": "process-video-08" },
    { "stationId": "process-09", "order": 9, "title": "Cán phẳng giấy", "titleEn": "Rolling and Flattening", "narration": "Giấy được cán phẳng trước khi hoàn thiện.", "narrationEn": "The paper is flattened before finishing.", "assetId": "process-video-09" },
    { "stationId": "process-10", "order": 10, "title": "Lột giấy sấy khô", "titleEn": "Peeling and Separating", "narration": "Giấy khô được lột khỏi vách sấy và xếp thành tệp.", "narrationEn": "Dried sheets are peeled from the drying wall and stacked.", "assetId": "process-video-10" }
  ]
