id: CHARTER
type: charter
status: {{status}}
owner: {{owner}}
version: {{version}}
# Pure-YAML SSOT: the Architecture Charter lists the goals every standard area
# must address. Each goal carries a REQUIRED metrics: list — a goal without a
# measurable target is not a charter goal. Goal ids follow ARCH-G<n>.
description: |
  Links the Engineering Vision (see vision) to the standard areas. Add one goal
  entry per architectural objective; every standard area declares which goals it
  addresses via its arch_goals: list.
goals:
  - id: {{goal_id}}
    title: {{goal_title}}
    status: {{goal_status}}
    owner: {{owner}}
    metrics: {{goal_metrics}}
