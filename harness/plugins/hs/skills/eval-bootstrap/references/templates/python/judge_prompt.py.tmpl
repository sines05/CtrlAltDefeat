"""
LLM judge prompt construction for ${domain} extraction quality assessment.

Scaffold variables:
    ${domain}             — eval domain name (e.g., cv_extraction)
    ${dimensions_json}    — dict of dimension_name -> weight (int, sums to 100)
                            from the approved strategy card; the SAME set
                            judge_runner validates its response against
    ${primary_dimension}  — the single dimension the P0 recommendation section
                            names (from the same card)

Builds the system + user prompts sent to the LLM judge. The domain is baked in
at scaffold time, so there is NO runtime .format() over the schema block (whose
literal JSON braces would otherwise raise KeyError) — the dimension-dependent
pieces below are built by plain string concatenation instead, for the same
reason.
"""

import json


DIMENSIONS = ${dimensions_json}


def _dims_list(dimensions: dict) -> str:
    """Comma-joined dimension names, in card order, for prose sentences."""
    return ", ".join(dimensions)


def _dims_schema_block(dimensions: dict) -> str:
    """The `"dimensions": {...}` JSON schema entries, one per declared dim."""
    lines = [
        '    "%s": {"score": <0-100>, "confidence": <0.0-1.0>, "findings": "<one-line summary>"}'
        % name
        for name in dimensions
    ]
    return ",\n".join(lines)


def _weights_instruction(dimensions: dict) -> str:
    """"name weight%, name weight%, ..." for the scoring-weights sentence."""
    return ", ".join("%s %d%%" % (name, weight) for name, weight in dimensions.items())


# Advisory P0-recommendation thresholds -- SINGLE SOURCE. judge_runner imports
# these to recompute p0_recommendation authoritatively; the prompt prose below
# is rendered from the SAME constants, so tuning one never desyncs the other.
P0_CONFIDENCE_THRESHOLD = 0.7
P0_PRIMARY_THRESHOLD = 60

SYSTEM_PROMPT = (
    """\
You are a quality auditor for a ${domain} extraction pipeline. Your job is to review
batch comparison results from a deterministic ground-truth eval and produce a
structured quality assessment.

## Role

You are NOT re-grading individual cases. The deterministic scorer already computed
per-field MATCH/MISMATCH/MISS/EXTRA results. Your job is to:
1. Detect patterns across failures that the per-field scorer cannot see
2. Assess holistic quality dimensions (""" + _dims_list(DIMENSIONS) + """)
3. Classify severity of issues
4. Recommend root-cause fixes

Your assessment is ADVISORY. It does not change the deterministic pass/fail verdict —
it adds pattern detection and recommendations on top of it.

## Rubric Reference

Use the scoring anchors and examples from the judge rubric. Key rules:
- Score each dimension 0-100 independently
- Borderline cases → score lower (err toward strictness)
- A pattern exists when 3+ cases share the same failure type
- Severity: CRITICAL (systemic), HIGH (pattern), MEDIUM (isolated significant), LOW (cosmetic)

## Output Schema

Return ONLY valid JSON (no markdown, no commentary outside the JSON object):

{
  "overall_score": <weighted average of dimensions, 0-100>,
  "confidence": <0.0-1.0, how confident you are in this assessment>,
  "dimensions": {
""" + _dims_schema_block(DIMENSIONS) + """
  },
  "patterns": [
    {
      "type": "<failure category>",
      "severity": "CRITICAL|HIGH|MEDIUM|LOW",
      "cases_affected": ["case1.pdf", "case2.pdf"],
      "field": "<field name or null>",
      "description": "<what the pattern is>"
    }
  ],
  "recommendations": [
    {
      "priority": 1,
      "category": "pipeline_mirror|normalizer|ground_truth|scorer",
      "description": "<actionable recommendation>"
    }
  ],
  "p0_triggered": false
}

## P0 Recommendation (advisory)

Set p0_triggered to true if:
- confidence < """ + str(P0_CONFIDENCE_THRESHOLD) + """ (you are not confident enough in this assessment)
- ${primary_dimension} score < """ + str(P0_PRIMARY_THRESHOLD) + """ (the primary dimension is scoring poorly)

A triggered p0_triggered is a RECOMMENDATION to block — the deterministic gate
remains the authority on release.
"""
)


def build_judge_prompt(comparison_results: list, ground_truth: dict, mirror_source: str) -> dict:
    """Assemble the evidence bundle and construct the judge prompt.

    Returns {"system": str, "user": str}.
    """
    total_cases = len(comparison_results)
    total_fields = 0
    matched = 0
    mismatched = 0
    missed = 0
    extra = 0
    skipped = 0
    errored_cases = 0
    per_case_breakdown = []

    for r in comparison_results:
        case_name = r.get("case", "unknown")
        if "error" in r:
            errored_cases += 1
            per_case_breakdown.append({
                "case": case_name, "error": r["error"], "passed": False, "fields": [],
            })
            continue

        case_fields = []
        for f in r.get("fields", []):
            total_fields += 1
            status = f["status"]
            if status == "MATCH":
                matched += 1
            elif status == "MISMATCH":
                mismatched += 1
            elif status == "MISS":
                missed += 1
            elif status == "EXTRA":
                extra += 1
            elif status == "SKIP":
                skipped += 1
            case_fields.append({
                "field": f["field"], "status": status,
                "extracted": f.get("extracted", ""), "expected": f.get("expected", ""),
            })
        per_case_breakdown.append({
            "case": case_name, "passed": r.get("passed", False),
            "notes": r.get("notes", ""), "fields": case_fields,
        })

    # A malformed ground_truth must not raise here — this is advisory-summary
    # only. Reduce each item to its ground_truth DICT (a non-dict item, or a
    # missing/null/truthy-non-dict ground_truth all collapse to {}), then summarise
    # off those maps so `.values()`/`.keys()` are always safe.
    gt_items = ground_truth.get("items") or []
    gt_maps = [
        (i.get("ground_truth") if isinstance(i, dict) and isinstance(i.get("ground_truth"), dict) else {})
        for i in gt_items
    ]
    gt_summary = {
        "description": ground_truth.get("description", ""),
        "n_items": len(gt_items),
        "field_names": list(gt_maps[0].keys()) if gt_maps else [],
        "annotated_items": sum(1 for g in gt_maps if any(v is not None for v in g.values())),
        "unannotated_items": sum(1 for g in gt_maps if all(v is None for v in g.values())),
    }

    evidence = {
        "summary": {
            "total_cases": total_cases, "total_fields": total_fields, "matched": matched,
            "mismatched": mismatched, "missed": missed, "extra": extra, "skipped": skipped,
            "errored_cases": errored_cases,
            "match_rate_pct": round(matched / total_fields * 100, 1) if total_fields else 0,
            "case_pass_rate_pct": round(
                sum(1 for r in comparison_results if r.get("passed", False)) / total_cases * 100, 1
            ) if total_cases else 0,
        },
        "ground_truth_summary": gt_summary,
        "per_case_breakdown": per_case_breakdown,
        "mirror_source": _truncate_source(mirror_source, max_lines=80),
    }

    user_prompt = (
        "Review the following evidence from a %d-case ${domain} extraction eval.\n\n"
        "## Evidence Bundle\n\n```json\n%s\n```\n\n"
        "## Instructions\n\n"
        "1. Score each of the %d quality dimensions (%s) using the rubric anchors. "
        "Weights: %s.\n"
        "2. Identify patterns — 3+ cases with the same failure type constitute a pattern.\n"
        "3. Classify each pattern's severity: CRITICAL, HIGH, MEDIUM, or LOW.\n"
        "4. Provide prioritized, actionable recommendations.\n"
        "5. Set p0_triggered if confidence < %s or ${primary_dimension} < %s.\n\n"
        "Return ONLY valid JSON per the output schema."
        % (total_cases, json.dumps(evidence, indent=2, ensure_ascii=False),
           len(DIMENSIONS), _dims_list(DIMENSIONS), _weights_instruction(DIMENSIONS),
           P0_CONFIDENCE_THRESHOLD, P0_PRIMARY_THRESHOLD)
    )

    return {"system": SYSTEM_PROMPT, "user": user_prompt}


def _truncate_source(source: str, max_lines: int = 80) -> str:
    """Truncate pipeline mirror source to prevent prompt overflow."""
    lines = source.split("\n")
    if len(lines) <= max_lines:
        return source
    return "\n".join(lines[:max_lines]) + ("\n# ... (%d more lines)" % (len(lines) - max_lines))
