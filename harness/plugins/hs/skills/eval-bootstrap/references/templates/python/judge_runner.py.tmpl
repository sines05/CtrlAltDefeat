"""
LLM judge runner for ${domain} — ADVISORY quality assessment.

Scaffold variables:
    ${domain}              — eval domain name (e.g., cv_extraction)
    ${judge_model}         — default model for judging (must differ from the pipeline)
    ${pipeline_model}      — the model the pipeline itself uses (R8 self-eval guard)
    ${scorer_module}       — import name for the scorer
    ${runner_module}       — import name for the runner
    ${mirror_module}       — import name for the pipeline mirror (source inspection)
    ${judge_prompt_module} — import name for the judge prompt builder
    ${dimensions_json}     — dict of dimension_name -> weight (int, sums to 100)
                             from the approved strategy card; the judge validates
                             its response against EXACTLY this set
    ${primary_dimension}   — the single dimension attach_judge_advisory reads for
                             the advisory P0 recommendation (from the same card)

The judge NEVER gates PASS/FAIL. Deterministic scoring is the sole authority on
the verdict; the judge attaches an ADVISORY report (patterns + recommendations)
that leaves maturity and passed untouched. Judge is optional (skip_judge=True
bypasses the LLM call entirely).
"""

from __future__ import annotations

import json
import os
import sys

from ${judge_prompt_module} import (
    build_judge_prompt,
    P0_CONFIDENCE_THRESHOLD,
    P0_PRIMARY_THRESHOLD,
)


DEFAULT_JUDGE_MODEL = "${judge_model}"
PIPELINE_MODEL = "${pipeline_model}"

# R8: the judge must not grade its own pipeline's model (self-eval bias).
assert DEFAULT_JUDGE_MODEL != PIPELINE_MODEL, (
    "R8: judge model (%s) must differ from the pipeline model (%s)"
    % (DEFAULT_JUDGE_MODEL, PIPELINE_MODEL))

# Quality dimensions + weights from the approved strategy card (L1) — the judge
# validates its response against EXACTLY this set. A response missing a card dim
# is fatal (ValueError); an extra dim the card never declared is a warn-and-ignore
# (judge models often return extras).
DIMENSIONS = ${dimensions_json}
PRIMARY_DIMENSION = "${primary_dimension}"

# Advisory-only P0 recommendation thresholds (never gate the release) --
# imported from ${judge_prompt_module} above so the prompt prose and this
# authoritative recompute read ONE source and cannot desync.


def run_judge(comparison_results, ground_truth, mirror_source, model=DEFAULT_JUDGE_MODEL):
    """Call the LLM judge and return its raw JSON response.

    The LLM call itself is left to the generated framework — the contract is:
        Input:  {"system": str, "user": str}   (from build_judge_prompt)
        Output: raw JSON string matching the judge output schema.
    """
    prompt = build_judge_prompt(comparison_results, ground_truth, mirror_source)

    # Replace this stub with the actual client call, e.g.:
    #   import anthropic
    #   client = anthropic.Anthropic()
    #   response = client.messages.create(
    #       model=model, max_tokens=2000,
    #       system=prompt["system"],
    #       messages=[{"role": "user", "content": prompt["user"]}])
    #   return response.content[0].text
    raise NotImplementedError(
        "LLM judge call must be implemented in the generated eval framework.\n"
        "Model: %s\n"
        "A ready-to-send prompt dict was built with keys: %s\n"
        "Expected output: raw JSON matching the judge output schema."
        % (model, sorted(prompt.keys())))


def parse_judge_response(raw_json: str) -> dict:
    """Parse and validate the LLM judge's JSON response."""
    try:
        output = json.loads(raw_json)
    except json.JSONDecodeError as e:
        raise ValueError("Judge returned invalid JSON: %s" % e)

    required_keys = ["overall_score", "confidence", "dimensions", "patterns",
                     "recommendations", "p0_triggered"]
    for key in required_keys:
        if key not in output:
            raise ValueError("Judge response missing required key: %s" % key)

    if not (0 <= output["overall_score"] <= 100):
        raise ValueError("overall_score out of range: %s" % output["overall_score"])
    if not (0 <= output["confidence"] <= 1):
        raise ValueError("confidence out of range: %s" % output["confidence"])

    for dim in DIMENSIONS:
        if dim not in output["dimensions"]:
            raise ValueError("Judge response missing dimension: %s" % dim)
        d = output["dimensions"][dim]
        if not (0 <= d.get("score", -1) <= 100):
            raise ValueError("Dimension %s score out of range: %s" % (dim, d.get("score")))
        if not (0 <= d.get("confidence", -1) <= 1):
            raise ValueError("Dimension %s confidence out of range: %s" % (dim, d.get("confidence")))

    extra_dims = [d for d in output["dimensions"] if d not in DIMENSIONS]
    if extra_dims:
        print("[JUDGE] Ignoring dimension(s) not declared on the card: %s"
              % ", ".join(sorted(extra_dims)), file=sys.stderr)

    return output


def attach_judge_advisory(deterministic_score: dict, judge_output: dict) -> dict:
    """Attach the judge's findings as an ADVISORY report.

    Returns the deterministic score verbatim (maturity, passed, p0_gate_passed
    all UNCHANGED) with a `judge_advisory` block added. The judge score never
    multiplies into maturity and never flips the verdict — p0_recommendation is
    a suggestion the human reads, not a gate.
    """
    primary_score = judge_output["dimensions"][PRIMARY_DIMENSION]["score"]
    p0_recommendation = (
        judge_output["confidence"] < P0_CONFIDENCE_THRESHOLD
        or primary_score < P0_PRIMARY_THRESHOLD
        or judge_output.get("p0_triggered", False))

    result = dict(deterministic_score)  # deterministic verdict passes through untouched
    result["judge_advisory"] = {
        "overall_score": judge_output["overall_score"],
        "confidence": judge_output["confidence"],
        "dimensions": judge_output["dimensions"],
        "patterns": judge_output["patterns"],
        "recommendations": judge_output["recommendations"],
        "p0_recommendation": p0_recommendation,
    }
    return result


def get_mirror_source(mirror_module: str) -> str:
    """Read the pipeline mirror source code for the judge to review."""
    import importlib.util
    spec = importlib.util.find_spec(mirror_module.replace("/", ".").replace(".py", ""))
    if spec and spec.origin:
        with open(spec.origin, encoding="utf-8") as f:
            return f.read()
    for path in ("evals/eval_types/${domain}/pipeline_mirror.py", "%s.py" % mirror_module):
        if os.path.exists(path):
            with open(path, encoding="utf-8") as f:
                return f.read()
    return "# Pipeline mirror source not found"


def run_eval_with_judge(sample_dir, ground_truth_path, skip_judge=False,
                        judge_model=DEFAULT_JUDGE_MODEL, precomputed=None):
    """Full pipeline: extract -> compare -> score (authoritative) -> judge (advisory).

    Returns (scored, judge_output|None). `scored` carries the DETERMINISTIC
    verdict; when the judge ran it also carries a `judge_advisory` block.

    `precomputed`, when given as (comparison_results, deterministic_score) from
    an earlier run_eval, is reused instead of re-running the whole deterministic
    eval -- on the subprocess-mirror lane that avoids launching every case's
    mirror a SECOND time just to feed the advisory judge.
    """
    from ${runner_module} import run_eval, load_ground_truth

    if precomputed is not None:
        comparison_results, deterministic_score = precomputed
    else:
        comparison_results, deterministic_score = run_eval(sample_dir, ground_truth_path)

    if skip_judge:
        print("[JUDGE] Skipped (--skip-judge)")
        return deterministic_score, None

    mirror_source = get_mirror_source("${mirror_module}")
    ground_truth = load_ground_truth(ground_truth_path)

    print("[JUDGE] Running advisory quality assessment with model=%s..." % judge_model)
    try:
        raw_judge_output = run_judge(comparison_results, ground_truth, mirror_source,
                                     model=judge_model)
        judge_output = parse_judge_response(raw_judge_output)
    except NotImplementedError:
        print("[JUDGE] LLM client not configured — advisory skipped. "
              "Implement run_judge() to enable it.")
        return deterministic_score, None
    except Exception as e:  # noqa: BLE001 — a judge failure must never block the run
        print("[JUDGE] Error during judging: %s" % e, file=sys.stderr)
        print("[JUDGE] Continuing with the deterministic verdict.")
        return deterministic_score, None

    final = attach_judge_advisory(deterministic_score, judge_output)
    adv = final["judge_advisory"]
    print("[JUDGE] Advisory score: %s/100 (confidence: %.2f). Deterministic verdict "
          "unchanged: %s" % (adv["overall_score"], adv["confidence"],
                             "PASS" if deterministic_score["passed"] else "FAIL"))
    if adv["p0_recommendation"]:
        print("[JUDGE] Advisory RECOMMENDS block — this does not override the deterministic gate.")

    return final, judge_output
