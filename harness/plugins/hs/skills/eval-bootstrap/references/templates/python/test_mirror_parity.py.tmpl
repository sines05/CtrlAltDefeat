"""
Mirror-vs-production parity test for ${domain}.

Verifies pipeline_mirror.run_pipeline (the dependency-free double — see
pipeline_mirror.py, NOT a mock) stays behaviourally IDENTICAL to production
(${production_module}). This is the "smoke alarm" that keeps the mirror
honest: a pipeline-logic change in production that never lands here trips
this test the next time it actually runs.

SKIP-HONESTY (load-bearing): parity EXERCISES production, so it only runs
where production's full dependency chain (config, schemas, models, API keys)
is importable — that is the target repo's full-dependency CI, not
necessarily an eval-only checkout (evals/ is a zero-dependency tree by
design, R1). When production import fails here, this module SKIPs with an
explicit message. A SKIP is NOT a pass: it means parity was never exercised,
not that it succeeded — never read a SKIP here as green.

CONTRACT: stdlib + pytest only. Re-verifies the strategy card's hash
(load_verified_config) BEFORE importing anything else, so a drifted card
fails loudly before any parity case runs.
"""

from __future__ import annotations

import importlib
import sys

from pathlib import Path

import pytest

# Stamped at evals/eval_types/${domain}/tests/test_mirror_parity.py:
#   parents[1] == the domain dir (siblings: pipeline_mirror.py, config_integrity.py)
#   parents[4] == the target repo root (parent of evals/) — needed so
#                 production_module (e.g. "src/x.py") resolves as an
#                 importable dotted module; a plain directory needs its
#                 PARENT on sys.path to be found as a namespace package.
_DOMAIN_DIR = Path(__file__).resolve().parents[1]
_REPO_ROOT = Path(__file__).resolve().parents[4]
for _p in (str(_DOMAIN_DIR), str(_REPO_ROOT)):
    if _p not in sys.path:
        sys.path.insert(0, _p)

from config_integrity import load_verified_config  # noqa: E402
from pipeline_mirror import run_pipeline  # noqa: E402

# Re-hash FIRST, at import time — a drifted card fails loudly before any
# parity case runs (same discipline as run_production_evals.py.tmpl).
_CONFIG = load_verified_config()
_CASE_MATRIX = _CONFIG["case_matrix"]
_PRODUCTION_MODULE = _CONFIG["production_module"]
_PRODUCTION_ENTRY = _CONFIG["production_entry"]


def _dotted(module_path: str) -> str:
    """Convert a card module path ("src/rule_based.py") to a dotted import
    name ("src.rule_based") — importlib.import_module needs the latter."""
    if module_path.endswith(".py"):
        module_path = module_path[:-3]
    return module_path.replace("/", ".")


def _resolve_production_entry():
    """Import the production entry named by the verified card.

    Returns (callable, None) on success, or (None, exception) on ANY import
    failure — missing dep / missing API key is EXPECTED in an eval-only
    checkout (R1), so the caller treats this as a skip, never a crash.
    """
    try:
        module = importlib.import_module(_dotted(_PRODUCTION_MODULE))
    except Exception as e:  # noqa: BLE001 — any import failure is a skip, not a crash
        return None, e
    entry = getattr(module, _PRODUCTION_ENTRY, None)
    if entry is None:
        return None, AttributeError(
            "%s has no attribute %r (production_entry)" % (_PRODUCTION_MODULE, _PRODUCTION_ENTRY))
    return entry, None


_PRODUCTION_ENTRY_FN, _PRODUCTION_IMPORT_ERROR = _resolve_production_entry()

# A module-level `pytest.skip(allow_module_level=True)` would collect ZERO
# items and make pytest exit 5 ("no tests collected") when this file runs
# alone — a SURPRISING non-pass exit code that looks like an error, not a
# skip. `pytestmark` instead marks every (still-collected) parametrized item
# skip, so the run is unambiguously "N skipped" at exit 0 — visible in a
# report, honest in a CI job, never confused with a crash.
pytestmark = pytest.mark.skipif(
    _PRODUCTION_ENTRY_FN is None,
    reason=(
        "production module %r unavailable here (%r) — parity only runs where "
        "src/ imports are satisfied (the target repo's full-dependency CI); "
        "a SKIP is NOT a pass, it means parity was never exercised."
        % (_PRODUCTION_MODULE, _PRODUCTION_IMPORT_ERROR)))


@pytest.mark.parametrize("case", _CASE_MATRIX, ids=[c["case"] for c in _CASE_MATRIX])
def test_mirror_matches_production(case):
    # case["input"] is already whatever native JSON type the approved card
    # declared (a string by default; a dict/list case runs through
    # unchanged) — both call sites receive it as-is, no re-decode, no
    # shape-guessing beyond what the card already committed to.
    case_input = case["input"]
    mirror_output = run_pipeline(case_input)
    production_output = _PRODUCTION_ENTRY_FN(case_input)
    assert mirror_output == production_output, (
        "pipeline_mirror diverged from production for case %r: mirror=%r production=%r"
        % (case["case"], mirror_output, production_output))
