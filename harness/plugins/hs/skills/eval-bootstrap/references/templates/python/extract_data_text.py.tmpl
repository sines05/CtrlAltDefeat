"""
Sidecar text extractor for ${domain} eval data.

Scaffold variables:
    ${domain}   — eval domain name

Walks a data directory and writes a `.txt` sidecar next to each .pdf / .docx
file (example-1.pdf -> example-1.pdf.txt). The eval runner reads these sidecars
instead of re-parsing binaries every run, so CI needs no PDF toolchain.

IMAGES ARE NOT OCR'd here. Extract text from an image with a model read at
bootstrap time (human review), then commit the `.txt` sidecar by hand — that
keeps the eval runner deterministic and API-key-free.

Dependencies (declare in evals/requirements.txt, install on request):
    pymupdf       — PDF text extraction (imported as `fitz`)
    python-docx   — DOCX text extraction (imported as `docx`)
Both are imported lazily so this module loads even when they are absent.
"""

from __future__ import annotations

import argparse
import os
import sys


PDF_EXTS = (".pdf",)
DOCX_EXTS = (".docx",)
IMAGE_EXTS = (".png", ".jpg", ".jpeg", ".gif", ".bmp", ".tiff", ".webp")


def extract_pdf(path: str) -> str:
    """Extract text from a PDF using pymupdf (fitz)."""
    import fitz  # pymupdf
    parts = []
    with fitz.open(path) as doc:
        for page in doc:
            parts.append(page.get_text())
    return "\n".join(parts)


def extract_docx(path: str) -> str:
    """Extract text from a DOCX using python-docx."""
    import docx
    document = docx.Document(path)
    return "\n".join(p.text for p in document.paragraphs)


def extract_text(path: str) -> str:
    """Dispatch on file extension. Raises ValueError for unsupported types."""
    ext = os.path.splitext(path)[1].lower()
    if ext in PDF_EXTS:
        return extract_pdf(path)
    if ext in DOCX_EXTS:
        return extract_docx(path)
    raise ValueError("Unsupported binary type for auto-extraction: %s" % ext)


def write_sidecar(path: str) -> str:
    """Extract text from `path` and write `<path>.txt`. Returns the sidecar path."""
    text = extract_text(path)
    sidecar = path + ".txt"
    with open(sidecar, "w", encoding="utf-8") as f:
        f.write(text)
    return sidecar


def main() -> None:
    parser = argparse.ArgumentParser(description="Write .txt sidecars for eval data files")
    parser.add_argument("--data-dir", required=True, help="Directory holding data files")
    parser.add_argument("--force", action="store_true", help="Rewrite existing sidecars")
    args = parser.parse_args()

    if not os.path.isdir(args.data_dir):
        print("ERROR: not a directory: %s" % args.data_dir, file=sys.stderr)
        sys.exit(1)

    written, skipped, images = 0, 0, 0
    for root, _dirs, files in os.walk(args.data_dir):
        for name in files:
            ext = os.path.splitext(name)[1].lower()
            path = os.path.join(root, name)
            if ext in IMAGE_EXTS:
                images += 1
                print("  IMAGE (extract with a model read, commit .txt by hand): %s" % path)
                continue
            if ext not in PDF_EXTS + DOCX_EXTS:
                continue
            sidecar = path + ".txt"
            if os.path.exists(sidecar) and not args.force:
                skipped += 1
                continue
            write_sidecar(path)
            written += 1
            print("  wrote %s" % sidecar)

    print("\nSidecars written: %d, skipped (exist): %d, images needing manual text: %d"
          % (written, skipped, images))


if __name__ == "__main__":
    main()
