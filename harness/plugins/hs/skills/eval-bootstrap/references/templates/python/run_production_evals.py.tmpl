"""
Production eval CLI entrypoint for ${domain}.

Scaffold variables:
    ${domain}              — eval domain name
    ${runner_module}       — import name for the runner
    ${judge_runner_module} — import name for the advisory judge runner

Runs the deterministic eval; the LLM judge is opt-in (--judge), advisory only,
and NEVER changes the exit code — the deterministic verdict is the gate.

Exit codes:
    0 — all scorable cases pass critical field extraction
    1 — one or more cases fail, or no scorable cases found (eval-fail)
    2 — a SETUP error, never a pipeline verdict: config drift (the strategy
        card's hash no longer matches its sidecar, or the card was never
        written), a bad --sample-dir/--ground-truth input path, or a card
        normalizer name with no matching NORMALIZERS entry
"""

from __future__ import annotations

import argparse
import os
import sys


# Put the domain's eval modules (runner/scorer/pipeline_mirror/config_integrity) on
# the import path.
_HERE = os.path.dirname(os.path.abspath(__file__))            # evals/scripts
_EVAL_DIR = os.path.join(os.path.dirname(_HERE), "eval_types", "${domain}")
if _EVAL_DIR not in sys.path:
    sys.path.insert(0, _EVAL_DIR)

from config_integrity import ConfigDriftError, load_verified_config


def main() -> None:
    parser = argparse.ArgumentParser(description="Production eval runner for ${domain}")
    parser.add_argument("--sample-dir", required=True, help="Directory containing test data files")
    parser.add_argument("--ground-truth", required=True, help="Path to ground_truth.json")
    parser.add_argument("--judge", action="store_true",
                        help="Also run the advisory LLM judge (does not change the exit code)")
    parser.add_argument("--judge-model", default=None, help="Override the judge model")
    args = parser.parse_args()

    # Integrity check FIRST — right after arg-parse, before any input-path
    # check and before importing the runner: a drifted card must never reach
    # a scoring pass, deterministic or advisory.
    try:
        load_verified_config()
    except ConfigDriftError as e:
        print("ERROR: %s" % e, file=sys.stderr)
        sys.exit(2)

    from ${runner_module} import NormalizerNotRegistered, run_eval, print_report

    if not os.path.isdir(args.sample_dir):
        print("ERROR: Cannot find sample directory: %s" % args.sample_dir, file=sys.stderr)
        sys.exit(2)
    if not os.path.isfile(args.ground_truth):
        print("ERROR: Cannot find ground truth file: %s" % args.ground_truth, file=sys.stderr)
        sys.exit(2)

    # A card-declared normalizer with no matching NORMALIZERS entry is a
    # SETUP error, not a legitimate eval verdict — must exit 2 (this bucket),
    # never 1 (which the gate reads as "the pipeline failed the eval").
    try:
        results, scored = run_eval(args.sample_dir, args.ground_truth)
    except NormalizerNotRegistered as e:
        print("ERROR: %s" % e, file=sys.stderr)
        sys.exit(2)
    print_report(results, scored)

    if args.judge:
        # Advisory pass — surfaces patterns + recommendations, never gates.
        try:
            from ${judge_runner_module} import run_eval_with_judge, DEFAULT_JUDGE_MODEL
            model = args.judge_model or DEFAULT_JUDGE_MODEL
            run_eval_with_judge(args.sample_dir, args.ground_truth,
                                skip_judge=False, judge_model=model,
                                precomputed=(results, scored))
        except Exception as e:  # noqa: BLE001 — advisory failure must not affect the gate
            print("[JUDGE] Advisory unavailable: %s" % e, file=sys.stderr)

    # The exit code follows the DETERMINISTIC verdict only.
    if not results:
        print("ERROR: No scorable cases found.", file=sys.stderr)
        sys.exit(1)
    sys.exit(0 if scored.get("passed", False) else 1)


if __name__ == "__main__":
    main()
