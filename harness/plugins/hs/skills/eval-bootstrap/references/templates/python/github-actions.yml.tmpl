name: Production Evals — {domain}

on:
  push:
    branches: [main, master]
    paths:
      - "src/**"
      - "evals/**"
      - "data/**"
  pull_request:
    branches: [main, master]
    paths:
      - "src/**"
      - "evals/**"
      - "data/**"

jobs:
  unit-tests:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "{python_version}"
      # {setup_steps} -- fill with the production stack's OWN interpreter/
      # toolchain install (e.g. actions/setup-node@v4, actions/setup-go@v5)
      # when the mirrored production_module is not Python; leave this
      # comment as-is (no-op) for a pure-Python stack.
      - name: Install dependencies
        run: {dependency_install_command}
      - name: Run unit tests
        run: {unit_test_command}

  eval-contract-tests:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "{python_version}"
      # {setup_steps} -- see unit-tests above; each job installs its own
      # runner, so the target-language toolchain fill is repeated here.
      - name: Install dependencies
        run: {dependency_install_command}
      - name: Run eval contract tests
        run: {eval_test_command}

  production-evals:
    runs-on: ubuntu-latest
    needs: [unit-tests, eval-contract-tests]
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "{python_version}"
      # {setup_steps} -- see unit-tests above.
      - name: Install dependencies
        run: {dependency_install_command}
      - name: Run production evals
        run: {run_evals_command}
