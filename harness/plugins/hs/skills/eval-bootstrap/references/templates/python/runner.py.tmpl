"""
Eval runner library for ${domain}: run_pipeline -> normalize -> compare -> score.

Scaffold variables:
    ${domain}             — eval domain name
    ${mirror_module}      — import name for the pipeline mirror
    ${scorer_module}      — import name for the deterministic scorer
    ${domain_config_json} — {"normalizers": {field: name}, "masks": {field: name}}
                             from the approved strategy card (L2: code only reads it)

Reads ground truth JSON, runs the pipeline mirror on each case, normalizes both
extracted and ground-truth values, compares field-by-field, and scores. This
module is a LIBRARY — the CLI entrypoint lives in run_production_evals.py.

Two mirror lanes (chosen ONCE per run_eval call, never per-case): a
mirror_contract.json stamped beside this file with a non-python `lang` routes
every case through the subprocess mirror contract; lang == python or no contract
at all keeps the original direct import (`from ${mirror_module} import
run_pipeline`) — zero new scaffold vars either way, every runtime value comes
from the contract file.
"""

import json
import os
import re
import subprocess
import tempfile
import unicodedata

from pathlib import Path


DOMAIN = "${domain}"

# field -> normalizer name, field -> mask name — a judgment value from the
# approved strategy card: the code only reads this, it never fills a blank in
# on its own — every judgment value comes from the card the human approved.
DOMAIN_CONFIG = ${domain_config_json}


# ── Normalization ─────────────────────────────────────────────────────

def normalize_generic(text) -> str:
    """Generic normalization: lowercase -> NFC -> whitespace collapse.

    Does NOT strip diacritics — diacritic folding is a LANGUAGE norm
    (judgment, L1), not a code default. A domain that needs it registers a
    language-specific profile in NORMALIZERS below (see the vi sample).
    """
    if text is None:
        return ""
    text = str(text)
    text = unicodedata.normalize("NFC", text)
    text = text.lower()
    text = re.sub(r"\s+", " ", text).strip()
    return text


def strip_diacritics(text: str) -> str:
    """Strip diacritics via NFD decomposition (Nguyễn Văn An -> Nguyen Van An).

    Kept as a building block for a language profile that opts into it (see
    the commented-out sample below) — NOT called by normalize_generic.
    """
    if not text:
        return text
    text = unicodedata.normalize("NFD", text)
    text = "".join(c for c in text if unicodedata.category(c) != "Mn")
    text = text.replace("Đ", "D").replace("đ", "d")
    return text


