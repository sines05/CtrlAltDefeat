# ── PII masking ───────────────────────────────────────────────────────

def mask_email(email: str) -> str:
    """Mask an email local-part: nguyenvana@gmail.com -> n********a@gmail.com"""
    if not email or "@" not in email:
        return email or ""
    local, domain = email.split("@", 1)
    if not local:  # '@gmail.com' — no local-part to index
        return "***@%s" % domain
    if len(local) <= 2:
        return "%s***@%s" % (local[0], domain)
    return "%s%s%s@%s" % (local[0], "*" * (len(local) - 2), local[-1], domain)


def mask_phone(phone: str) -> str:
    """Mask phone middle digits: 0912345678 -> 091*****78"""
    if not phone or len(phone) < 7:
        return phone or ""
    return "%s%s%s" % (phone[:3], "*" * (len(phone) - 5), phone[-2:])


# ── Registry: config-driven normalize/mask routing ────────────────────

NORMALIZERS = {"generic": normalize_generic}   # name -> fn; a new profile registers here (R9 flow)
MASKS = {"email": mask_email, "phone": mask_phone}  # name -> fn — the helpers stay generic; only ROUTING is config-driven


class NormalizerNotRegistered(Exception):
    """A card declared a normalizer name with no matching NORMALIZERS entry —
    a SETUP error the CLI catches and exits 2 on, never a bare KeyError:
    silently letting this escape as an uncaught error would masquerade a
    fill-in gap as a legitimate eval BLOCK (exit 1)."""


def normalize_field(field: str, value) -> str:
    """Normalize `value` for `field` using DOMAIN_CONFIG's routing.

    An unmapped field falls back to the "generic" normalizer; a name the card
    DOES declare but that has no NORMALIZERS entry raises
    NormalizerNotRegistered rather than silently falling back (a wrong-name
    typo must not score as if it were "generic")."""
    name = DOMAIN_CONFIG.get("normalizers", {}).get(field, "generic")
    fn = NORMALIZERS.get(name)
    if fn is None:
        raise NormalizerNotRegistered(
            "normalizer %r not registered — fill it (R9 flow) before running" % name)
    return fn("" if value is None else str(value))


def mask_value(field_name: str, value: str) -> str:
    """Apply PII masking routed via DOMAIN_CONFIG — a field not declared in
    the card's masks map is NOT masked (that is a card decision, not a
    field-name guess)."""
    if not value:
        return value
    name = DOMAIN_CONFIG.get("masks", {}).get(field_name)
    fn = MASKS.get(name)
    if fn is None:
        return value
    return fn(value)


# ── Comparison ────────────────────────────────────────────────────────

def compare_field(field_name: str, extracted, ground_truth) -> dict:
    """Compare a single field after normalization.

    Returns a dict with field, status (MATCH|MISMATCH|MISS|EXTRA|SKIP), and
    masked + raw extracted/expected values.
    """
    gt_is_null = ground_truth is None or (isinstance(ground_truth, str) and ground_truth.strip() == "")
    ex_is_null = extracted is None or (isinstance(extracted, str) and extracted.strip() == "")

    if gt_is_null and ex_is_null:
        status = "SKIP"
    elif gt_is_null and not ex_is_null:
        status = "EXTRA"
    elif not gt_is_null and ex_is_null:
        status = "MISS"
    elif normalize_field(field_name, extracted) == normalize_field(field_name, ground_truth):
        status = "MATCH"
    else:
        status = "MISMATCH"

    # Only None becomes a blank cell — a real 0 / 0.0 / False must display as
    # itself, not vanish into "" (which would hide the value behind a MISMATCH).
    ex_disp = "" if extracted is None else str(extracted)
    gt_disp = "" if ground_truth is None else str(ground_truth)
    return {
        "field": field_name,
        "status": status,
        "extracted": mask_value(field_name, ex_disp),
        "expected": mask_value(field_name, gt_disp),
        "extracted_raw": ex_disp,
        "expected_raw": gt_disp,
    }


# ── Runner ────────────────────────────────────────────────────────────

def _errored_case(case, error) -> dict:
    """A per-case error record. One bad case must never abort the whole run, so
    every failure mode in run_eval funnels through this single shape."""
    return {"case": case, "error": error, "fields": [], "passed": False}


def load_ground_truth(path: str) -> dict:
    """Load and validate ground truth JSON (a dict with a list-valued 'items')."""
    with open(path, encoding="utf-8") as f:
        gt = json.load(f)
    if not isinstance(gt, dict) or "items" not in gt:
        raise ValueError("ground_truth.json must be an object with an 'items' key")
    if not isinstance(gt["items"], list):
        raise ValueError("ground_truth.json 'items' must be a list")
    return gt


# ── Subprocess mirror lane (the mirror_contract.json consumer) ────────

def _load_mirror_contract():
    """Load mirror_contract.json stamped beside this runner (emitted by
    eval_config.py emit-mirror-contract) — None means "no contract yet", the
    signal that keeps run_eval on the original direct-import lane. `__file__`
    is absent when this module is
    exec'd from a bare source string rather than a real file (a template
    render-only test fixture) — that must read as "no contract" too, not
    crash with a NameError.
    """
    try:
        here = Path(__file__).resolve().parent
    except NameError:
        return None
    contract_path = here / "mirror_contract.json"
    if not contract_path.is_file():
        return None
    with open(contract_path, encoding="utf-8") as f:
        return json.load(f)


def _verify_contract_hash(contract: dict) -> None:
    """Confirm mirror_contract.json's card_hash still matches the currently
    approved config — die LOUD and EARLY (before any case runs) if the
    contract was generated against a card that has since been re-approved.
    Reuses config_integrity's own drift check (load_verified_config re-hashes
    eval_config.json against its sha256 sidecar and raises ConfigDriftError on
    mismatch) instead of re-deriving the hash a second way; once that check
    has passed, the sidecar's own text IS the current hash.
    """
    from config_integrity import ConfigDriftError, load_verified_config

    load_verified_config()  # raises ConfigDriftError if the card itself drifted
    root = Path(__file__).resolve().parents[2]
    current_hash = "sha256:" + (root / "eval_config.sha256").read_text(encoding="utf-8").strip()
    if contract.get("card_hash") != current_hash:
        raise ConfigDriftError(
            "mirror_contract.json card_hash (%s) does not match the current "
            "approved config (%s) — re-emit the contract: "
            "eval_config.py --emit-mirror-contract"
            % (contract.get("card_hash"), current_hash))


def _resolve_mirror_path(contract: dict, here: "Path") -> str:
    """Resolve the target-lang mirror file beside this runner. Prefer
    `mirror_filename` (the emitter always sets it); fall back to a
    pipeline_mirror.* glob only for an older contract missing the field.

    Defense-in-depth: the emitter always writes a safe basename, so a
    traversal here is not reachable via the normal write -> emit -> run
    flow — but nothing stops a human from hand-editing mirror_contract.json
    to set `mirror_filename` to "../../etc/passwd" or an absolute path.
    Refuse anything that resolves outside `here` rather than trust the
    contract file blindly.
    """
    filename = contract.get("mirror_filename")
    if filename:
        here_resolved = here.resolve()
        candidate = (here_resolved / filename).resolve()
        try:
            contained = os.path.commonpath([str(candidate), str(here_resolved)]) == str(here_resolved)
        except ValueError:
            contained = False  # different drives on Windows -- never contained
        if not contained:
            raise RuntimeError(
                "mirror_filename %r resolves outside the eval dir %s -- "
                "refusing a hand-edited contract that escapes its own directory"
                % (filename, here_resolved))
        return str(candidate)
    matches = sorted(here.glob("pipeline_mirror.*"))
    if not matches:
        raise RuntimeError(
            "no pipeline_mirror.* file found beside runner.py "
            "(contract carries no mirror_filename either)")
    return str(matches[0])


def _build_mirror_argv(argv_template: list, mirror_path: str, input_path: str) -> list:
    """Render argv_template's {mirror_path}/{input_file} placeholders.

    The built-in per-lang tables (eval_config.py's _LANG_INVOKE) carry no
    {input_file} token — they only render "how do you normally run a <lang>
    file". A template that never places {input_file} gets the arg-file path
    appended as a trailing positional arg instead (the mirror guide's
    "wherever the arg-file path lands"); a card's own `mirror_invoke` MAY
    place {input_file} explicitly for a different argument order.
    """
    rendered = []
    saw_input_file = False
    for token in argv_template:
        new_token = token.replace("{mirror_path}", mirror_path)
        if "{input_file}" in new_token:
            new_token = new_token.replace("{input_file}", input_path)
            saw_input_file = True
        rendered.append(new_token)
    if not saw_input_file:
        rendered.append(input_path)
    return rendered


# Minimal allowlist forwarded to the mirror subprocess (R1): naming exactly
# these keys is the safest way to add the go/ruby/rust build-cache vars
# without reopening "forward the parent environment" — a mirror in one of
# those languages needs HOME or XDG_CACHE_HOME (`go run` dies with "build
# cache is required ... neither $$XDG_CACHE_HOME nor $$HOME are defined" on a
# PATH-only env, so every case errors and the whole run blocks). The
# Windows names are the equivalent minimum a native toolchain needs there.
_ENV_ALLOWLIST = ("PATH", "HOME", "TMPDIR", "XDG_CACHE_HOME")
_ENV_ALLOWLIST_WINDOWS = ("SystemRoot", "SYSTEMROOT", "TEMP", "TMP")

# Defense-in-depth on top of the allowlist itself (R1: zero inherited
# secrets) — even an allowlisted name is dropped if it looks like a secret
# or carries one of the common provider/harness prefixes, so a future
# allowlist edit cannot silently reopen the leak.
_ENV_SECRET_TOKEN_RE = re.compile(r"KEY|TOKEN|SECRET|PASSWORD", re.IGNORECASE)
_ENV_SECRET_PREFIXES = ("HARNESS_", "ANTHROPIC_", "OPENAI_", "AWS_")


def _build_mirror_env() -> dict:
    """Build the MINIMAL environment forwarded to the mirror subprocess —
    never the full os.environ. Only the named allowlist keys are copied from
    the parent process, and only when present; anything matching a secret
    pattern or a provider/harness prefix is skipped even if allowlisted."""
    names = list(_ENV_ALLOWLIST)
    if os.name == "nt":
        names += list(_ENV_ALLOWLIST_WINDOWS)
    env = {}
    for name in names:
        if _ENV_SECRET_TOKEN_RE.search(name) or name.startswith(_ENV_SECRET_PREFIXES):
            continue  # unreachable for the current allowlist, kept as a hard floor
        value = os.environ.get(name)
        if value is not None:
            env[name] = value
    env.setdefault("PATH", "/usr/bin:/bin")
    return env


def _run_mirror_case(contract: dict, input_text: str) -> dict:
    """Invoke the target-language pipeline mirror over subprocess per the
    contract: write the case input to a UTF-8 tempfile, build argv, run with
    the MINIMAL allowlisted environment from `_build_mirror_env` (R1 keeps
    zero API keys / zero inherited secrets; do NOT pass the full os.environ
    through), and parse stdout as exactly ONE JSON object.

    Every failure mode here (timeout, non-zero exit, missing interpreter,
    malformed/multi-doc/non-object stdout) RAISES — the caller's existing
    per-case try/except (the same one that already isolates a broken
    `run_pipeline` in the import lane) turns that into an isolated error
    record; this function never aborts the run itself.
    """
    here = Path(__file__).resolve().parent
    mirror_path = _resolve_mirror_path(contract, here)

    tmp = tempfile.NamedTemporaryFile(
        mode="w", suffix=".txt", encoding="utf-8", delete=False)
    try:
        tmp.write(input_text)
        tmp.close()
        argv = _build_mirror_argv(contract["invoke"]["argv_template"], mirror_path, tmp.name)
        env = _build_mirror_env()

        try:
            proc = subprocess.run(
                argv, capture_output=True, text=True,
                timeout=contract["timeout_seconds"], env=env)
        except subprocess.TimeoutExpired:
            raise RuntimeError(
                "mirror timed out after %ss: %s" % (contract["timeout_seconds"], argv))
        except FileNotFoundError:
            raise RuntimeError("mirror interpreter not found: %s" % argv[0])

        if proc.returncode != 0:
            raise RuntimeError(
                "mirror exited %d (stderr: %s)" % (proc.returncode, proc.stderr.strip()))

        try:
            parsed = json.loads(proc.stdout)
        except json.JSONDecodeError as e:
            raise RuntimeError(
                "mirror stdout is not valid JSON: %s (stderr: %s)" % (e, proc.stderr.strip()))

        if not isinstance(parsed, dict):
            raise RuntimeError(
                "mirror stdout must be a single JSON object, got %s (stderr: %s)"
                % (type(parsed).__name__, proc.stderr.strip()))
        return parsed
    finally:
        try:
            os.unlink(tmp.name)
        except OSError:
            pass


def run_eval(sample_dir: str, ground_truth_path: str) -> tuple:
    """Run the eval: run_pipeline -> compare -> score. Returns (per_case_results, scored).

    Dispatch (resolved ONCE, before the case loop, never per-case): a
    mirror_contract.json beside this file with `lang` != "python" routes every
    case through `_run_mirror_case` (the subprocess mirror contract); lang ==
    python or no contract at all takes the original direct-import lane
    unchanged (regression lock).
    """
    contract = _load_mirror_contract()
    use_subprocess = contract is not None and contract.get("lang") != "python"

    if use_subprocess:
        _verify_contract_hash(contract)
    else:
        from ${mirror_module} import run_pipeline
    from ${scorer_module} import score

    gt = load_ground_truth(ground_truth_path)
    all_results = []

    for item in gt["items"]:
        # A malformed ground-truth item (not a dict, or a missing/blank/non-str
        # case_file) must not abort the whole run — a non-str case_file would raise
        # in os.path.join below, OUTSIDE any per-case guard. Record + move on.
        case_file = item.get("case_file") if isinstance(item, dict) else None
        if not isinstance(case_file, str) or not case_file.strip():
            all_results.append(_errored_case("<invalid item>", "ground-truth item has a missing/invalid 'case_file'"))
            continue
        case_path = os.path.join(sample_dir, case_file)
        sidecar_path = case_path + ".txt"

        # Prefer the pre-extracted .txt sidecar (avoids re-parsing binaries each run).
        # A sidecar that is not valid UTF-8 (wrong encoding / corrupt) must not abort
        # the run either — isolate it exactly like the raw-case read below.
        if os.path.exists(sidecar_path):
            try:
                with open(sidecar_path, encoding="utf-8") as f:
                    input_text = f.read()
            except (UnicodeDecodeError, OSError) as e:
                all_results.append(_errored_case(case_file, "Unreadable .txt sidecar: %s" % e))
                continue
        elif os.path.exists(case_path):
            # A raw binary case (PDF/DOCX) with no .txt sidecar is not UTF-8 text;
            # isolate the decode error per-case instead of aborting the whole run.
            try:
                with open(case_path, encoding="utf-8") as f:
                    input_text = f.read()
            except (UnicodeDecodeError, OSError) as e:
                all_results.append(_errored_case(case_file, "Unreadable case (no .txt sidecar?): %s" % e))
                continue
        else:
            all_results.append(_errored_case(case_file, "File not found: %s" % case_path))
            continue

        try:
            extracted = _run_mirror_case(contract, input_text) if use_subprocess else run_pipeline(input_text)
        except Exception as e:  # noqa: BLE001 — a broken pipeline mirror must not abort the run
            all_results.append(_errored_case(case_file, "Pipeline error: %s" % e))
            continue

        # A broken pipeline mirror that returns a non-dict (e.g. a missing return ->
        # None) must not abort the run either — the guard above only catches raises.
        if not isinstance(extracted, dict):
            all_results.append(_errored_case(
                case_file, "Pipeline mirror returned %s, expected dict" % type(extracted).__name__))
            continue

        # `ground_truth` absent/null == "no fields defined" (a vacuous skip); but a
        # present-yet-wrong-type value ([], "", 0, a list) is malformed and must be
        # flagged, NOT silently coerced to {} (which would score the case a false PASS).
        ground_truth_fields = item.get("ground_truth")
        if ground_truth_fields is None:
            ground_truth_fields = {}
        elif not isinstance(ground_truth_fields, dict):
            all_results.append(_errored_case(
                case_file, "ground_truth must be an object, got %s" % type(ground_truth_fields).__name__))
            continue
        field_results = []
        for field_name, expected_value in ground_truth_fields.items():
            extracted_value = extracted.get(field_name)
            field_results.append(compare_field(field_name, extracted_value, expected_value))

        statuses = [f["status"] for f in field_results]
        case_passed = "MISS" not in statuses and "MISMATCH" not in statuses

        all_results.append({
            "case": case_file,
            "notes": item.get("notes", ""),
            "fields": field_results,
            "passed": case_passed,
        })

    scored = score(all_results)
    return all_results, scored


def print_report(results: list, scored: dict) -> None:
    """Print a PII-safe results table."""
    print("\n" + "=" * 80)
    print("  PRODUCTION EVAL RESULTS — %s" % DOMAIN)
    print("=" * 80)

    for r in results:
        case = r["case"]
        if "error" in r:
            print("\n  %s: ERROR — %s" % (case, r["error"]))
            continue

        status_icon = "PASS" if r["passed"] else "FAIL"
        print("\n  %s: %s" % (case, status_icon))
        if r.get("notes"):
            print("    Notes: %s" % r["notes"])
        for f in r["fields"]:
            print("    [%-8s] %-20s  expected=%-30s  got=%s"
                  % (f["status"], f["field"], f["expected"], f["extracted"]))

    print("\n" + "-" * 80)
    print("  MATURITY SCORE: %s%% (threshold: %s%%)" % (scored["maturity"], scored["threshold"]))
    print("  P0 GATE: %s" % ("PASS" if scored["p0_gate_passed"] else "BLOCK"))
    for f in scored["p0_failures"]:
        print("    P0 FAILURE: %s" % f)
    print("  OVERALL: %s" % ("PASS" if scored["passed"] else "FAIL"))
    print("-" * 80)

    print("\n  Dimension Scores:")
    for dim_name, dim_data in scored["dimensions"].items():
        print("    %-20s  weight=%3d%%  score=%5.1f%%  weighted=%5.1f"
              % (dim_name, dim_data["weight"], dim_data["score"], dim_data["weighted"]))
    print("\n" + "=" * 80)
