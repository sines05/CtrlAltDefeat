{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "gemini-review-output",
  "description": "Structured output a gemini advisory/review run is asked to return. Every record carries provenance so a gemini finding is never mistaken for a Claude one (D6). The companion validates required fields with a mini checker (no jsonschema dep).",
  "type": "object",
  "required": ["verdict", "provenance", "findings"],
  "properties": {
    "verdict": {
      "enum": ["PASS", "PASS_WITH_RISK", "FAIL"],
      "description": "Overall judgment of the reviewed material"
    },
    "provenance": {
      "type": "object",
      "required": ["reviewer_engine", "reviewer_model"],
      "properties": {
        "reviewer_engine": {"enum": ["gemini", "agy"], "description": "The winning diagonal engine for this lane"},
        "reviewer_model": {"type": "string", "description": "Resolved model id behind the run"},
        "purpose": {"type": "string", "description": "review | adversarial-review | research | delegate"},
        "ts": {"type": "string", "description": "ISO-8601 timestamp"},
        "actor": {"type": "string", "description": "resolve_actor() attribution"}
      }
    },
    "findings": {
      "type": "array",
      "description": "Individual findings; empty = nothing surfaced",
      "items": {
        "type": "object",
        "required": ["severity", "summary"],
        "properties": {
          "severity": {"enum": ["critical", "high", "medium", "low", "nit"]},
          "summary": {"type": "string", "description": "One-sentence statement of the finding"},
          "evidence": {"type": "string", "description": "file:line / quote / repro — never translated"},
          "recommendation": {"type": "string", "description": "Concrete fix or next step"}
        }
      }
    }
  }
}
