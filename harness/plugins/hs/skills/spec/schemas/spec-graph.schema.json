{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hs.harness/spec/spec-graph.schema.json",
  "title": "hs:spec traceability graph",
  "description": "Shape of the graph JSON produced by spec_graph.build_graph(root).",
  "type": "object",
  "required": ["version", "product", "nodes", "edges", "risks", "competitors", "parse_errors", "root_path"],
  "properties": {
    "version": {"type": "string"},
    "generated_at": {"type": "string"},
    "product": {"type": "object"},
    "missing_product_dir": {"type": "boolean"},
    "root_path": {"type": "string"},
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": {"type": ["string", "null"]},
          "type": {"type": ["string", "null"]},
          "title": {"type": "string"}
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "kind"],
        "properties": {
          "from": {"type": "string"},
          "to": {"type": "string"},
          "kind": {"type": "string", "enum": ["epic", "prd", "brd_goal"]}
        }
      }
    },
    "risks": {"type": "array"},
    "competitors": {"type": "array"},
    "parse_errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "error"],
        "properties": {
          "file": {"type": "string"},
          "error": {"type": ["string", "null"]}
        }
      }
    }
  }
}
