<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="Page-1">
    <mxGraphModel>
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Container 200x200 -->
        <mxCell id="container" value="Box" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="100" y="100" width="200" height="200" as="geometry" />
        </mxCell>
        <!-- Child spills right: x+w = 150+120=270 > 200 -->
        <mxCell id="spill_right" value="A" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="container">
          <mxGeometry x="150" y="20" width="120" height="40" as="geometry" />
        </mxCell>
        <!-- Child spills bottom: y+h = 170+80=250 > 200 -->
        <mxCell id="spill_bottom" value="B" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="container">
          <mxGeometry x="20" y="170" width="80" height="80" as="geometry" />
        </mxCell>
        <!-- Child OK: fully inside -->
        <mxCell id="ok_child" value="C" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="container">
          <mxGeometry x="10" y="10" width="80" height="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
