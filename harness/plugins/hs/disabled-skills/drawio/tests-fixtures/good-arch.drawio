<mxfile host="drawio">
  <diagram name="Good Architecture">
    <mxGraphModel>
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- AWS Cloud → Region → VPC → AZ → Subnet → SG (correct nesting) -->
        <mxCell id="2" value="AWS Cloud" style="shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_aws_cloud;strokeColor=none;fillColor=none;dashed=0;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="720" height="520" as="geometry"/>
        </mxCell>
        <mxCell id="3" value="Region" style="shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_region;strokeColor=none;fillColor=none;dashed=0;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;rounded=0;" vertex="1" parent="2">
          <mxGeometry x="20" y="20" width="680" height="480" as="geometry"/>
        </mxCell>
        <mxCell id="4" value="VPC" style="shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_vpc;strokeColor=#248814;fillColor=#FFFFFF;dashed=1;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;rounded=0;" vertex="1" parent="3">
          <mxGeometry x="20" y="20" width="640" height="440" as="geometry"/>
        </mxCell>
        <mxCell id="5" value="EC2" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2;" vertex="1" parent="4">
          <mxGeometry x="80" y="60" width="78" height="78" as="geometry"/>
        </mxCell>
        <mxCell id="6" value="RDS" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.rds;" vertex="1" parent="4">
          <mxGeometry x="240" y="60" width="78" height="78" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
