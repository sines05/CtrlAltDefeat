<mxfile host="drawio">
  <diagram name="Bad Nesting">
    <mxGraphModel>
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Security Group directly on page (parent=1) — no Cloud/Region/VPC/AZ/Subnet ancestor -->
        <mxCell id="2" value="Security Group" style="shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_security_group;strokeColor=#DD3522;fillColor=#FFFFFF;dashed=1;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="300" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="3" value="EC2" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2;" vertex="1" parent="2">
          <mxGeometry x="40" y="40" width="78" height="78" as="geometry"/>
        </mxCell>
        <!-- Also: VPC directly on page, no Cloud ancestor -->
        <mxCell id="4" value="VPC" style="shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_vpc;strokeColor=#248814;fillColor=#FFFFFF;dashed=1;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="400" y="40" width="300" height="200" as="geometry"/>
        </mxCell>
        <!-- GROUP_LEVEL violations: SG and VPC at root level -->
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
