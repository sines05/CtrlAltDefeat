#!/bin/sh
# harness — courier lifecycle dispatcher (setup / upgrade / version / path / doctor).
#
# Resolves its own engine from $0 (a marketplace cache puts the engine beside the
# wrapper) or from HARNESS_BIN_ROOT / the engine-home `current` pointer, then execs
# the Python lifecycle tool. No engine resolvable -> an actionable error, never a
# silent no-op. Pure POSIX sh so it runs on any adopter's default shell.
set -eu

# Portable realpath for $0 (macOS `realpath` lacks -f on older systems).
_resolve() {
    p=$1
    while [ -h "$p" ]; do
        d=$(cd -P "$(dirname "$p")" >/dev/null 2>&1 && pwd)
        l=$(readlink "$p")
        case $l in
            /*) p=$l ;;
            *)  p=$d/$l ;;
        esac
    done
    d=$(cd -P "$(dirname "$p")" >/dev/null 2>&1 && pwd)
    printf '%s/%s\n' "$d" "$(basename "$p")"
}

SELF=$(_resolve "$0")
SELFDIR=$(dirname "$SELF")

# Candidate engine roots, first existing wins. An engine root E carries
# E/harness/scripts/harness_lifecycle.py.
ENGINE=""
# ${HOME:-} guards `set -u`: if BOTH XDG_DATA_HOME and HOME are unset (a minimal
# container / some systemd/cron contexts), a bare $HOME here would abort the whole
# script BEFORE the loop even tries the sibling-engine candidate (which needs no HOME).
_home_data=${XDG_DATA_HOME:-${HOME:-}/.local/share}
for cand in \
    "$SELFDIR/../engine" \
    "$SELFDIR/../.." \
    "${HARNESS_BIN_ROOT:-}" \
    "$_home_data/harness/current"
do
    [ -n "$cand" ] || continue
    if [ -f "$cand/harness/scripts/harness_lifecycle.py" ]; then
        ENGINE=$(cd -P "$cand" >/dev/null 2>&1 && pwd)
        break
    fi
done

if [ -z "$ENGINE" ]; then
    cat >&2 <<'ERR'
harness: no engine found. This dispatcher could not locate the harness engine
next to itself, via $HARNESS_BIN_ROOT, or under the engine home
(~/.local/share/harness/current).

If you just installed the plugin, run:  harness setup
Otherwise (re)install the harness plugin from your marketplace, then run setup.
ERR
    exit 1
fi

# Tell the lifecycle tool where the cache engine sits, so `setup` copies FROM it.
export HARNESS_COURIER_CACHE="$ENGINE"
exec python3 "$ENGINE/harness/scripts/harness_lifecycle.py" "$@"
